  },
  {
    title: "Ingeniero de Sistemas",
    company: "PROYECTO: SISTEMA DE CHECK-IN",
    period: "Q1 2026",
    location: "REMOTO",
    tasks: [
      "Diseño de un sistema de asistencia de empleados enfocado en la precisión temporal, geográfica, y la integridad de datos.",
      "Desarrollo de una API REST robusta con endpoints críticos para gestión en tiempo real de entradas, almuerzos e incidencias.",
      "Implementación de flujos de trabajo optimizados para ofrecer flexibilidad en horarios y gestión de asistencias.",
      "Arquitectura e implementacion de un sistema de autenticacion, autorizacion y manejo de roles con tokens JWT y middleware personalizado.",
    ],
    tags: ["GO", "REST API", "FIBER", "SQLX", "JWT", "POSTGRES", "SVELTE", "TailwindCSS"]
  },
  {
    title: "Desarrollador de Software de Escritorio",
    company: "PROYECTO: OWOWERLAYS",
    period: "Q4 2025 - Q1 2026",
    location: "WINDOWS_OS",
    tasks: [
      "Desarrollo de una aplicación de escritorio ligera para personalización avanzada de la interfaz de Windows.",
      "Renderizado gráfico de bajo nivel usando C# y GDI+ para procesamiento visual de alto rendimiento.",
      "Gestión de persistencia a nivel de sistema y optimización de recursos para ejecución sin latencia.",
      "Optimización del rendimiento de la aplicación para asegurar una experiencia fluida, sin interrupciones, y con mínimo consumo de recursos."
    ],
    tags: ["C#", ".NET", "WINFORMS", "GDI+"]
  },
  {
    title: "Arquitecto Frontend",
    company: "PROYECTO: WEB ONG ASAOSA",
    period: "Q4 2025 - Q1 2026",
    location: "WEB_STATIC",
    tasks: [
      "Desarrollo de un sitio web de alto rendimiento para una organización sin fines de lucro usando Eleventy y Nunjucks como motor de plantillas.",
