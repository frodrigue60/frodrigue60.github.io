---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t('page.contact.title')} | Luis Rodz`}>
  <main class="flex-grow flex flex-col items-center justify-center px-6 py-12 relative z-10 w-full max-w-[1280px] mx-auto min-h-[calc(100vh-130px)]">
    <!-- Decorative Brackets Wrapper -->
    <div class="relative w-full max-w-2xl">
      <!-- Brackets -->
      <div class="absolute -top-4 -left-4 w-8 h-8 border-t-2 border-l-2 border-[#3B3B3B] pointer-events-none"></div>
      <div class="absolute -top-4 -right-4 w-8 h-8 border-t-2 border-r-2 border-[#3B3B3B] pointer-events-none"></div>
      <div class="absolute -bottom-4 -left-4 w-8 h-8 border-b-2 border-l-2 border-[#3B3B3B] pointer-events-none"></div>
      <div class="absolute -bottom-4 -right-4 w-8 h-8 border-b-2 border-r-2 border-[#3B3B3B] pointer-events-none"></div>

      <!-- Form Container -->
      <div class="bg-[#D2CEB6]/10 border border-[#3B3B3B] p-8 md:p-12 relative shadow-none backdrop-blur-sm">
        <!-- Header -->
        <div class="border-b-2 border-[#3B3B3B] pb-6 mb-10 flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
           <h1 class="text-5xl font-display text-[#3B3B3B] uppercase">{t('page.contact.title')}</h1>
          <div class="font-technical text-[12px] text-[#3B3B3B] flex items-center gap-2 uppercase tracking-widest font-black bg-[#3B3B3B]/5 px-3 py-1 border border-[#3B3B3B]/10">
            {t('page.contact.sys_req')}
          </div>
        </div>

        <!-- Form Fields -->
        <form id="contact-form" class="space-y-10">
          <div class="relative group">
            <label class="absolute -top-[12px] left-0 font-technical text-[12px] font-black text-[#3B3B3B]/80 bg-[#CDC9B0] px-2 transition-colors group-focus-within:text-[#3B3B3B] uppercase tracking-tighter" for="name">{t('page.contact.op_name')}</label>
            <input 
              class="w-full bg-transparent border-0 border-b-2 border-[#3B3B3B]/40 py-4 px-1 font-technical text-[16px] font-bold text-[#3B3B3B] focus:ring-0 focus:border-[#3B3B3B] transition-colors placeholder:text-[#3B3B3B]/40 uppercase" 
              id="name" 
              name="name" 
              placeholder={t('page.contact.op_name_placeholder')} 
              required 
              type="text"
            />
          </div>

          <div class="relative group">
            <label class="absolute -top-[12px] left-0 font-technical text-[12px] font-black text-[#3B3B3B]/80 bg-[#CDC9B0] px-2 transition-colors group-focus-within:text-[#3B3B3B] uppercase tracking-tighter" for="email">{t('page.contact.secure_relay')}</label>
            <input 
              class="w-full bg-transparent border-0 border-b-2 border-[#3B3B3B]/40 py-4 px-1 font-technical text-[16px] font-bold text-[#3B3B3B] focus:ring-0 focus:border-[#3B3B3B] transition-colors placeholder:text-[#3B3B3B]/40 uppercase" 
              id="email" 
              name="email" 
              placeholder={t('page.contact.secure_relay_placeholder')} 
              required 
              type="email"
            />
          </div>

          <div class="relative group">
            <label class="absolute -top-[12px] left-0 font-technical text-[12px] font-black text-[#3B3B3B]/80 bg-[#CDC9B0] px-2 transition-colors group-focus-within:text-[#3B3B3B] uppercase tracking-tighter" for="subject">{t('page.contact.mission_param')}</label>
            <input 
              class="w-full bg-transparent border-0 border-b-2 border-[#3B3B3B]/40 py-4 px-1 font-technical text-[16px] font-bold text-[#3B3B3B] focus:ring-0 focus:border-[#3B3B3B] transition-colors placeholder:text-[#3B3B3B]/40 uppercase" 
              id="subject" 
              name="subject" 
              placeholder={t('page.contact.mission_param_placeholder')} 
              required 
              type="text"
            />
          </div>

          <div class="relative group mt-12">
            <label class="absolute -top-[12px] left-0 font-technical text-[12px] font-black text-[#3B3B3B]/80 bg-[#CDC9B0] px-2 transition-colors group-focus-within:text-[#3B3B3B] uppercase tracking-tighter" for="message">{t('page.contact.data_transmission')}</label>
            <div class="absolute top-0 right-0 p-1 border-l border-b border-[#3B3B3B] bg-[#D2CEB6]/20 dotted-bg w-8 h-8 pointer-events-none"></div>
            <textarea 
              class="w-full bg-transparent border-2 border-[#3B3B3B]/40 p-4 font-technical text-[15px] text-[#3B3B3B] focus:ring-0 focus:border-[#3B3B3B] transition-colors resize-none placeholder:text-[#3B3B3B]/40" 
              id="message" 
              name="message" 
              placeholder={t('page.contact.data_transmission_placeholder')} 
              required 
              rows="5"
            ></textarea>
          </div>

          <!-- Status Message Relay -->
          <div id="form-status" class="hidden font-technical text-[11px] font-bold p-3 border uppercase tracking-wider items-center justify-between">
            <span id="status-text"></span>
            <span id="status-dot" class="w-2 h-2"></span>
          </div>

          <!-- Submit Command -->
          <div class="pt-6 flex justify-end">
            <button class="group relative flex items-center gap-4 border-2 border-[#3B3B3B] bg-transparent px-10 py-4 font-technical text-[14px] font-black text-[#3B3B3B] hover:bg-[#3B3B3B] hover:text-[#CDC9B0] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-transparent disabled:hover:text-[#3B3B3B] transition-all duration-150 cursor-pointer overflow-hidden uppercase tracking-widest" type="submit">
              <span class="relative z-10">{t('page.contact.submit')}</span>
              <div class="absolute inset-0 bg-[#3B3B3B] translate-y-full group-hover:translate-y-0 transition-transform duration-150"></div>
            </button>
          </div>
        </form>
      </div>
    </div>
  </main>
</Layout>

<script define:vars={{ statusSending: t('page.contact.status_sending'), statusSuccess: t('page.contact.status_success'), statusError: t('page.contact.status_error'), accessKey: '6a958f7c-b784-42ce-a81f-ad47f3d7a2ac' }}>
  const form = document.getElementById('contact-form');
  const statusDiv = document.getElementById('form-status');
  const statusText = document.getElementById('status-text');
  const statusDot = document.getElementById('status-dot');
  const submitBtn = form.querySelector('button[type="submit"]');
  let statusTimeout;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (statusTimeout) {
      clearTimeout(statusTimeout);
    }
    
    // Set loading state
    submitBtn.disabled = true;
    statusDiv.className = "flex font-technical text-[11px] font-bold p-3 border uppercase tracking-wider items-center justify-between text-[#3B3B3B]/60 border-[#3B3B3B]/20 bg-[#3B3B3B]/5";
    statusText.textContent = statusSending;
    statusDot.className = "w-2 h-2 bg-[#3B3B3B]/40 animate-pulse";
    statusDiv.classList.remove('hidden');

    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    object.access_key = accessKey;

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json"
        },
        body: JSON.stringify(object)
      });
      const result = await response.json();
      
      if (response.status === 200 && result.success) {
        statusDiv.className = "flex font-technical text-[11px] font-bold p-3 border uppercase tracking-wider items-center justify-between text-[#8A9A5B] border-[#8A9A5B] bg-[#8A9A5B]/10";
        statusText.textContent = statusSuccess;
        statusDot.className = "w-2 h-2 bg-[#8A9A5B] animate-ping";
        form.reset();
        
        statusTimeout = setTimeout(() => {
          statusDiv.classList.add('hidden');
        }, 5000); // Hide after 5 seconds
      } else {
        throw new Error(result.message || "Submission failed");
      }
    } catch (error) {
      console.error(error);
      statusDiv.className = "flex font-technical text-[11px] font-bold p-3 border uppercase tracking-wider items-center justify-between text-red-700 border-red-700 bg-red-700/10";
      statusText.textContent = statusError;
      statusDot.className = "w-2 h-2 bg-red-700 animate-bounce";
      
      statusTimeout = setTimeout(() => {
        statusDiv.classList.add('hidden');
      }, 6000); // Hide after 6 seconds
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .font-technical { font-family: var(--font-technical); }
  .font-display { font-family: var(--font-display); }
  .font-body { font-family: var(--font-body); }
  
  input::placeholder, textarea::placeholder {
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.05em;
  }
</style>
