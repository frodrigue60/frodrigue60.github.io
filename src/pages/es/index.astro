---
import Layout from "../../layouts/Layout.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import thumbnailAnirank from "../../images/thumbnail-anirank.png";
import { Image } from "astro:assets";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t("page.home.title")} | Luis Rodz`}>
  <div
    class="flex flex-1 w-full max-w-[1200px] mx-auto overflow-hidden min-h-[calc(100vh-130px)]"
  >
    <!-- Content Area -->
    <main
      class="flex-1 p-8 lg:p-12 overflow-y-auto flex flex-col gap-12 font-body"
    >
      <!-- Hero -->
      <section
        class="flex flex-col gap-4 border-[3px] border-[#3B3B3B] p-8 relative bg-[#D2CEB6]/20"
      >
        <div class="absolute top-2 right-2 flex gap-1">
          <div class="w-2 h-2 border border-[#3B3B3B]"></div>
          <div class="w-2 h-2 border border-[#3B3B3B] bg-[#3B3B3B]"></div>
        </div>
        <div
          class="flex flex-col md:flex-row gap-4 items-baseline border-b-2 border-[#3B3B3B] pb-4 mb-4"
        >
          <h1 class="text-4xl md:text-5xl font-display uppercase leading-none">
            {t("hero.title")}
          </h1>
          <span class="text-[11px] font-technical text-[#3B3B3B]/60 uppercase"
            >{t("hero.profile")}</span
          >
        </div>
        <p class="text-lg max-w-2xl text-[#3B3B3B]/80 font-body">
          {t("hero.desc_p")}
        </p>
        <div class="flex flex-wrap gap-4 mt-4">
          <button
            class="border border-[#3B3B3B] px-6 py-2 hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors flex items-center gap-2 text-[11px] font-bold uppercase font-technical"
          >
            <span class="material-symbols-outlined text-sm">download</span>
            {t("hero.download_cv")}
            <span class="ml-2 text-[10px] border border-current px-1"
              >[ PDF ]</span
            >
          </button>
          <button
            class="border border-[#3B3B3B]/40 text-[#3B3B3B]/60 px-6 py-2 hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors flex items-center gap-2 text-[11px] font-bold uppercase font-technical"
          >
            {t("hero.contact")}
          </button>
        </div>
      </section>

      <!-- Projects Grid -->
      <section id="proyectos" class="grid grid-cols-1 xl:grid-cols-3 gap-8">
        <!-- Featured Project Module -->
        <article
          class="xl:col-span-3 border-[3px] border-[#3B3B3B] bg-[#D2CEB6]/10 flex flex-col md:flex-row relative"
        >
          <div
            class="absolute -top-3 -left-3 w-6 h-6 border-t-[3px] border-l-[3px] border-[#3B3B3B]"
          >
          </div>
          <div
            class="absolute -bottom-3 -right-3 w-6 h-6 border-b-[3px] border-r-[3px] border-[#3B3B3B]"
          >
          </div>
          <div
            class="flex-1 p-6 border-b md:border-b-0 md:border-r border-[#3B3B3B]"
          >
            <div
              class="text-[10px] font-bold text-[#3B3B3B]/60 mb-4 flex items-center gap-2 border-b border-[#3B3B3B]/20 pb-2 font-technical uppercase"
            >
              <span class="material-symbols-outlined text-sm">database</span>
              {t("projects.featured_tag")}
            </div>
            <div
              class="relative w-full aspect-video border border-[#3B3B3B] bg-[#3B3B3B]/5 mb-4 overflow-hidden group"
            >
              <Image
                src={thumbnailAnirank}
                alt="Vista previa proyecto"
                class="w-full h-full object-cover mix-blend-luminosity opacity-80 group-hover:opacity-100 transition-opacity grayscale group-hover:grayscale-0"
                width={1200}
                height={630}
              />
              <div
                class="absolute top-2 left-2 bg-[#CDC9B0] text-[#3B3B3B] text-[9px] font-bold px-2 py-1 border border-[#3B3B3B] font-technical"
              >
                {t("projects.preview_tag")}
              </div>
            </div>
            <p class="text-sm text-[#3B3B3B]/80 font-body">
              {t("projects.featured_desc")}
            </p>
          </div>
          <aside class="w-full md:w-80 p-6 bg-[#D2CEB6]/20 flex flex-col gap-6">
            <div>
              <div
                class="text-[9px] font-bold text-[#3B3B3B]/40 mb-1 font-technical uppercase"
              >
                {t("projects.tech")}
              </div>
              <div class="grid grid-cols-2 gap-2">
                <ul
                  class="flex flex-col gap-1 border-l-2 border-[#3B3B3B] pl-3 font-technical"
                >
                  <li class="text-[11px] font-bold uppercase">SvelteKit</li>
                  <li class="text-[11px] font-bold uppercase">Tailwind CSS</li>
                  <li class="text-[11px] font-bold uppercase">Bun</li>
                  <li class="text-[11px] font-bold uppercase">TypeScript</li>
                </ul>

                <ul
                  class="flex flex-col gap-1 border-l-2 border-[#3B3B3B] pl-3 font-technical"
                >
                  <li class="text-[11px] font-bold uppercase">Golang</li>
                  <li class="text-[11px] font-bold uppercase">Fiber</li>
                  <li class="text-[11px] font-bold uppercase">SQLX</li>
                  <li class="text-[11px] font-bold uppercase">JWT</li>
                  <li class="text-[11px] font-bold uppercase">PostgreSQL</li>
                </ul>
              </div>
            </div>
            <div>
              <div
                class="text-[9px] font-bold text-[#3B3B3B]/40 mb-1 font-technical uppercase"
              >
                {t("projects.stats")}
              </div>
              <div class="grid grid-cols-2 gap-2 text-[11px] font-technical">
                <div class="border border-[#3B3B3B]/20 p-2">
                  <div class="text-[#3B3B3B]/40 text-[8px] mb-1">
                    {t("projects.perf")}
                  </div>
                  <div class="font-bold">99.9%</div>
                </div>
                <div class="border border-[#3B3B3B]/20 p-2">
                  <div class="text-[#3B3B3B]/40 text-[8px] mb-1">
                    {t("projects.status")}
                  </div>
                  <div class="font-bold text-[#8A9A5B]">OK</div>
                </div>
              </div>
            </div>
            <div class="mt-auto">
              <div
                class="text-[9px] font-bold text-[#8A9A5B] mb-1 font-technical uppercase"
              >
                {t("projects.deploy")}
              </div>
              <div
                class="border border-[#8A9A5B] p-2 flex items-center justify-between bg-[#8A9A5B]/10"
              >
                <span class="font-bold text-[10px] text-[#8A9A5B]"
                  >{t("projects.active")}</span
                >
                <span class="w-2 h-2 bg-[#8A9A5B] animate-pulse"></span>
              </div>
            </div>
          </aside>
        </article>

        <!-- Secondary Module 1 -->
        <article
          class="border-[3px] border-[#3B3B3B] bg-[#D2CEB6]/10 p-6 relative"
        >
          <div
            class="text-[10px] font-bold text-[#3B3B3B]/60 mb-4 flex items-center justify-between border-b border-[#3B3B3B]/20 pb-2 font-technical uppercase"
          >
            <span>{t("about.section")}</span>
            <span class="material-symbols-outlined text-[14px]">person</span>
          </div>
          <div
            class="text-xl font-technical mb-2 uppercase border-l-4 border-[#3B3B3B] pl-2 font-bold"
          >
            {t("about.title")}
          </div>
          <p class="text-sm text-[#3B3B3B]/80 font-body mb-6">
            {t("about.desc")}
          </p>
          <div
            class="flex justify-between items-center mt-auto border-t border-[#3B3B3B]/20 pt-4"
          >
            <span
              class="text-[10px] bg-[#3B3B3B]/5 px-2 py-1 border border-[#3B3B3B]/20 font-technical"
              >v2.4.1</span
            >
            <button
              class="hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors border border-[#3B3B3B] px-3 py-1 text-[9px] font-bold uppercase font-technical"
              >{t("about.inspect")}</button
            >
          </div>
        </article>

        <!-- Secondary Module 2 -->
        <article
          class="border-[3px] border-[#3B3B3B] bg-[#D2CEB6] p-6 relative flex flex-col h-full"
        >
          <div
            class="text-[10px] font-bold text-[#3B3B3B] mb-4 flex items-center justify-between border-b border-[#3B3B3B]/30 pb-2 font-technical uppercase"
          >
            <span>{t("skills.section")}</span>
            <span class="material-symbols-outlined text-[14px]">widgets</span>
          </div>
          <div
            class="text-2xl font-technical mb-2 uppercase border-l-4 border-[#3B3B3B] pl-2 text-[#3B3B3B] font-bold"
          >
            {t("skills.title")}
          </div>
          <p
            class="text-[12px] text-[#3B3B3B]/80 font-technical mb-6 uppercase tracking-wide"
          >
            {t("skills.desc")}
          </p>

          <div class="space-y-8 mb-8">
            <!-- Backend Group -->
            <div>
              <span
                class="text-[10px] font-bold text-[#3B3B3B] uppercase block mb-2 font-technical tracking-widest border-l-2 border-[#3B3B3B] pl-2"
                >Backend_Core</span
              >
              <div class="flex flex-wrap gap-2">
                {
                  [
                    "Go",
                    "PHP / Laravel",
                    "Node.js",
                    "REST_API",
                    "Bun",
                    "TypeScript",
                  ].map((skill) => (
                    <span class="text-[11px] font-black border-2 border-[#3B3B3B] bg-[#3B3B3B]/5 px-3 py-1 font-technical uppercase text-[#3B3B3B] hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors cursor-default">
                      {skill}
                    </span>
                  ))
                }
              </div>
            </div>

            <!-- Frontend Group -->
            <div>
              <span
                class="text-[10px] font-bold text-[#3B3B3B] uppercase block mb-2 font-technical tracking-widest border-l-2 border-[#3B3B3B] pl-2"
                >Frontend_Interfaz</span
              >
              <div class="flex flex-wrap gap-2">
                {
                  [
                    "Svelte",
                    "Astro",
                    "Tailwind_CSS",
                    "Eleventy",
                    "Nunjucks",
                    "HTML5",
                    "CSS3",
                    "JavaScript",
                    "Bootstrap",
                  ].map((skill) => (
                    <span class="text-[11px] font-black border-2 border-[#3B3B3B] bg-[#3B3B3B]/5 px-3 py-1 font-technical uppercase text-[#3B3B3B] hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors cursor-default">
                      {skill}
                    </span>
                  ))
                }
              </div>
            </div>

            <!-- Infra/Data Group -->
            <div>
              <span
                class="text-[10px] font-bold text-[#3B3B3B] uppercase block mb-2 font-technical tracking-widest border-l-2 border-[#3B3B3B] pl-2"
                >Infraestructura_Datos</span
              >
              <div class="flex flex-wrap gap-2">
                {
                  [
                    "PostgreSQL",
                    "MySQL",
                    "Redis",
                    "Cloudflare",
                    "Docker",
                    "S3_MinIO",
                  ].map((skill) => (
                    <span class="text-[11px] font-black border-2 border-[#3B3B3B] bg-[#3B3B3B]/5 px-3 py-1 font-technical uppercase text-[#3B3B3B] hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors cursor-default">
                      {skill}
                    </span>
                  ))
                }
              </div>
            </div>

            <!-- Herramientas y Ecosistema -->
            <div>
              <span
                class="text-[10px] font-bold text-[#3B3B3B] uppercase block mb-2 font-technical tracking-widest border-l-2 border-[#3B3B3B] pl-2"
                >Herramientas_Ecosistema</span
              >
              <div class="flex flex-wrap gap-2">
                {
                  [
                    "VS Code",
                    "NPM / PNPM",
                    "Cloudflare_Pages",
                    "Cloudflare_Tunnels",
                    "AI_Pairing",
                    "Git/GitHub",
                  ].map((skill) => (
                    <span class="text-[11px] font-black border-2 border-[#3B3B3B] bg-[#3B3B3B]/5 px-3 py-1 font-technical uppercase text-[#3B3B3B] hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors cursor-default">
                      {skill}
                    </span>
                  ))
                }
              </div>
            </div>
          </div>
          <div
            class="flex justify-between items-center mt-auto border-t border-[#3B3B3B]/20 pt-4"
          >
            <span
              class="text-[11px] text-[#3B3B3B] font-bold font-technical bg-[#8A9A5B]/20 border border-[#8A9A5B]/40 px-3 py-1 uppercase"
              >{t("skills.updated")}</span
            >
            <span
              class="text-[11px] font-bold text-[#3B3B3B] font-technical uppercase border-b border-[#3B3B3B] cursor-pointer hover:text-[#3B3B3B]/60 transition-colors"
              >{t("skills.details")}</span
            >
          </div>
        </article>
      </section>
    </main>
  </div>
</Layout>

<style>
  /* Custom styles for the index page */
  .font-technical {
    font-family: var(--font-technical);
  }
  .font-display {
    font-family: var(--font-display);
  }
  .font-body {
    font-family: var(--font-body);
  }

  /* Ensure scrollbar looks industrial if possible */
  main::-webkit-scrollbar {
    width: 8px;
  }
  main::-webkit-scrollbar-track {
    background: var(--bg-color);
  }
  main::-webkit-scrollbar-thumb {
    background: var(--outline-color);
    border: 2px solid var(--bg-color);
  }
</style>
