---
---
<div id="language-splash" class="fixed inset-0 z-[100] flex items-center justify-center bg-[#CDC9B0] overflow-hidden">
    <!-- Inline script to prevent flicker -->
    <script is:inline>
        if (localStorage.getItem('preferred-lang')) {
            document.getElementById('language-splash').style.display = 'none';
        }
    </script>

    <div class="absolute inset-0 pointer-events-none scanlines opacity-30"></div>
    <div class="absolute inset-0 bg-[#CDC9B0]/90 backdrop-blur-sm z-0"></div>
    
    <main class="relative z-10 w-full max-w-2xl px-6">
        <div class="relative">
            <!-- Decorative Brackets -->
            <div class="absolute -top-4 -left-4 w-10 h-10 border-t-2 border-l-2 border-[#3B3B3B]"></div>
            <div class="absolute -top-4 -right-4 w-10 h-10 border-t-2 border-r-2 border-[#3B3B3B]"></div>
            <div class="absolute -bottom-4 -left-4 w-10 h-10 border-b-2 border-l-2 border-[#3B3B3B]"></div>
            <div class="absolute -bottom-4 -right-4 w-10 h-10 border-b-2 border-r-2 border-[#3B3B3B]"></div>

            <div class="border-2 border-[#3B3B3B] bg-[#CDC9B0] p-1.5">
                <div class="border border-[#3B3B3B]/30 bg-[#D2CEB6]/30 p-8 md:p-12 relative">
                    <div class="absolute top-0 right-0 p-4 opacity-30">
                        <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">terminal</span>
                    </div>
                    
                    <header class="border-b-2 border-[#3B3B3B] pb-6 mb-8 flex flex-col gap-2">
                        <h1 class="text-2xl md:text-3xl font-technical font-bold uppercase text-[#3B3B3B] tracking-tight">INITIALIZING_LANGUAGE_PROTOCOL</h1>
                        <p class="text-[10px] font-bold text-[#3B3B3B]/60 tracking-widest font-technical uppercase">SELECT PRIMARY COMMUNICATION INTERFACE</p>
                    </header>

                    <div class="flex flex-col gap-4">
                        <button data-lang="en" class="lang-btn group w-full flex items-center justify-between border border-[#3B3B3B] bg-transparent p-4 hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-all">
                            <span class="font-technical font-bold text-sm tracking-widest uppercase">[ ENGLISH ]</span>
                            <span class="font-technical text-[10px] border border-[#3B3B3B] group-hover:border-[#CDC9B0] px-2 py-1">[ 01 ]</span>
                        </button>
                        
                        <button data-lang="es" class="lang-btn group w-full flex items-center justify-between border border-[#3B3B3B] bg-transparent p-4 hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-all">
                            <span class="font-technical font-bold text-sm tracking-widest uppercase">[ ESPAÑOL ]</span>
                            <span class="font-technical text-[10px] border border-[#3B3B3B] group-hover:border-[#CDC9B0] px-2 py-1">[ 02 ]</span>
                        </button>

                        <button class="group w-full flex items-center justify-between border border-[#3B3B3B]/20 bg-transparent p-4 opacity-40 cursor-not-available">
                            <span class="font-technical font-bold text-sm tracking-widest uppercase">[ 日本語 ]</span>
                            <span class="font-technical text-[10px] border border-[#3B3B3B]/20 px-2 py-1">[ 03 ]</span>
                        </button>
                    </div>

                    <footer class="mt-12 pt-4 border-t border-[#3B3B3B]/20 flex flex-col gap-3">
                        <div class="flex justify-between items-center font-technical text-[9px] font-bold text-[#3B3B3B] uppercase">
                            <span class="flex items-center gap-2">
                                <span class="w-2 h-2 bg-[#8A9A5B] block"></span>
                                LINK_STATUS: STABLE
                            </span>
                            <span class="opacity-40">AWAITING_INPUT</span>
                        </div>
                        <div class="h-3 w-full border border-[#3B3B3B] dotted-bg relative flex">
                            <div class="w-2/3 h-full bg-[#3B3B3B] border-r border-[#3B3B3B]"></div>
                        </div>
                    </footer>
                </div>
            </div>
        </div>
    </main>
</div>

<script>
    const splash = document.getElementById('language-splash');
    const buttons = document.querySelectorAll('.lang-btn');

    buttons.forEach(btn => {
        btn.addEventListener('click', () => {
            const lang = btn.getAttribute('data-lang');
            localStorage.setItem('preferred-lang', lang);
            
            // Dispatch event for other components (like Navbar)
            window.dispatchEvent(new Event('lang-changed'));
            
            // Add a simple fade out effect
            splash.style.opacity = '0';
            splash.style.transition = 'opacity 0.5s ease';
            
            setTimeout(() => {
                splash.style.display = 'none';
            }, 500);
        });
    });
</script>

<style>
    .font-technical { font-family: var(--font-technical); }
    .dotted-bg {
        background-image: radial-gradient(var(--text-muted) 1px, transparent 1px);
        background-size: 4px 4px;
    }
    .scanlines {
        background-image: repeating-linear-gradient(0deg, transparent, transparent 1px, rgba(59, 59, 59, 0.05) 1px, rgba(59, 59, 59, 0.05) 2px);
        background-size: 100% 4px;
    }
</style>
