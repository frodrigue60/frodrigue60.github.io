---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Lógica para el selector de idioma
const currentPath = Astro.url.pathname;
let purePath = currentPath;
if (currentPath.startsWith('/es/')) {
    purePath = currentPath.replace('/es/', '/');
} else if (currentPath === '/es') {
    purePath = '/';
}
const nextLang = lang === 'en' ? 'es' : 'en';
const nextUrl = nextLang === 'en' ? purePath : `/es${purePath === '/' ? '' : purePath}`;
---
<header class="bg-[#CDC9B0] text-[#3B3B3B] docked full-width top-0 border-b-2 border-[#3B3B3B] flex justify-between items-center w-full px-6 h-16 z-40 sticky">
    <div class="flex items-center gap-8">
        <div class="text-lg font-black tracking-tighter text-[#3B3B3B]">PORTFOLIO_v1.0</div>
        
        <!-- Desktop Nav -->
        <nav class="hidden md:flex gap-6">
            <a class="font-serif uppercase tracking-widest text-[10px] font-bold text-[#3B3B3B]/60 hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-all duration-75 px-2 py-1" href={translatePath('/')}>{t('nav.home')}</a>
            <a class="font-serif uppercase tracking-widest text-[10px] font-bold text-[#3B3B3B]/60 hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-all duration-75 px-2 py-1" href={translatePath('/projects')}>{t('nav.projects')}</a>
            <a class="font-serif uppercase tracking-widest text-[10px] font-bold text-[#3B3B3B]/60 hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-all duration-75 px-2 py-1" href={translatePath('/history')}>{t('nav.history')}</a>
            <a class="font-serif uppercase tracking-widest text-[10px] font-bold text-[#3B3B3B]/60 hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-all duration-75 px-2 py-1" href={translatePath('/contact')}>{t('nav.contact')}</a>
        </nav>
    </div>
    <div class="flex items-center gap-4 md:gap-6">
        <!-- Language Selector (Desktop) -->
        <a href={nextUrl} class="hidden sm:flex items-center border border-[#3B3B3B] px-3 py-1 font-technical text-[10px] font-bold text-[#3B3B3B] hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-all no-underline">
            [ {lang.toUpperCase()} ]
        </a>
        
        <!-- Status Indicator -->
        <div class="hidden sm:flex items-center gap-4">
            <div class="font-serif uppercase tracking-widest text-[10px] font-bold">{t('nav.status')}</div>
            <span class="material-symbols-outlined text-lg">terminal</span>
        </div>

        <!-- Mobile Menu Toggle Button -->
        <button id="mobile-menu-btn" class="md:hidden flex items-center gap-2 border border-[#3B3B3B] px-3 py-1 font-technical text-[10px] font-bold text-[#3B3B3B] hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors">
            [ {t('nav.menu')} ]
            <span class="material-symbols-outlined text-sm">menu</span>
        </button>
    </div>
</header>

<!-- Mobile Drawer -->
<div id="mobile-drawer" class="fixed inset-0 bg-[#CDC9B0] z-50 translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col border-l-4 border-[#3B3B3B]">
    <div class="h-16 border-b-2 border-[#3B3B3B] flex items-center justify-between px-6 bg-[#CDC9B0]">
        <div class="text-lg font-black tracking-tighter text-[#3B3B3B]">PORTFOLIO_v1.0</div>
        <button id="close-menu-btn" class="flex items-center border border-[#3B3B3B] px-2 py-1 hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors">
            <span class="material-symbols-outlined text-sm">close</span>
        </button>
    </div>
    
    <div class="flex-1 overflow-y-auto p-6 flex flex-col gap-8 scanlines">
        <div class="text-[10px] font-bold text-[#3B3B3B]/60 tracking-widest uppercase border-b border-[#3B3B3B]/20 pb-2">
            {t('nav.sys_nav')}
        </div>
        
        <nav class="flex flex-col gap-4">
            <a class="flex items-center justify-between text-[#3B3B3B] hover:text-[#CDC9B0] hover:bg-[#3B3B3B] border border-transparent hover:border-[#3B3B3B] p-4 transition-colors font-technical font-bold text-xl uppercase tracking-widest" href={translatePath('/')}>
                {t('nav.home')}
                <span class="material-symbols-outlined">chevron_right</span>
            </a>
            <a class="flex items-center justify-between text-[#3B3B3B] hover:text-[#CDC9B0] hover:bg-[#3B3B3B] border border-transparent hover:border-[#3B3B3B] p-4 transition-colors font-technical font-bold text-xl uppercase tracking-widest" href={translatePath('/projects')}>
                {t('nav.projects')}
                <span class="material-symbols-outlined">chevron_right</span>
            </a>
            <a class="flex items-center justify-between text-[#3B3B3B] hover:text-[#CDC9B0] hover:bg-[#3B3B3B] border border-transparent hover:border-[#3B3B3B] p-4 transition-colors font-technical font-bold text-xl uppercase tracking-widest" href={translatePath('/history')}>
                {t('nav.history')}
                <span class="material-symbols-outlined">chevron_right</span>
            </a>
            <a class="flex items-center justify-between text-[#3B3B3B] hover:text-[#CDC9B0] hover:bg-[#3B3B3B] border border-transparent hover:border-[#3B3B3B] p-4 transition-colors font-technical font-bold text-xl uppercase tracking-widest" href={translatePath('/contact')}>
                {t('nav.contact')}
                <span class="material-symbols-outlined">chevron_right</span>
            </a>
        </nav>

        <div class="mt-auto pt-8 border-t border-[#3B3B3B]/20 flex flex-col gap-6">
            <div class="flex flex-col gap-2">
                <div class="text-[10px] font-bold text-[#3B3B3B]/60 tracking-widest uppercase">
                    {t('nav.lang_label')}
                </div>
                <a href={nextUrl} class="flex items-center justify-center border-2 border-[#3B3B3B] p-3 font-technical text-sm font-bold text-[#3B3B3B] hover:bg-[#3B3B3B] hover:text-[#CDC9B0] transition-colors bg-[#D2CEB6]/30">
                    {t('nav.change_lang')}
                </a>
            </div>

            <div class="flex items-center justify-between bg-[#3B3B3B] text-[#CDC9B0] p-4 border border-[#3B3B3B]">
                <div class="font-serif uppercase tracking-widest text-[10px] font-bold">{t('nav.status')}</div>
                <span class="material-symbols-outlined text-lg">terminal</span>
            </div>
        </div>
    </div>
</div>

<script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('close-menu-btn');
    const drawer = document.getElementById('mobile-drawer');

    if (menuBtn && closeBtn && drawer) {
        menuBtn.addEventListener('click', () => {
            drawer.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden'; // Prevent scrolling
        });

        closeBtn.addEventListener('click', () => {
            drawer.classList.add('translate-x-full');
            document.body.style.overflow = '';
        });
    }
</script>

<style>
    header {
        font-family: var(--font-technical);
    }
    
    nav a {
        font-family: var(--font-display);
    }

    .scanlines {
        background-image: repeating-linear-gradient(0deg, transparent, transparent 1px, rgba(59, 59, 59, 0.05) 1px, rgba(59, 59, 59, 0.05) 2px);
        background-size: 100% 4px;
    }
</style>
